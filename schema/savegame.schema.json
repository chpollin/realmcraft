{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/chpollin/realmcraft/schema/savegame.schema.json",
  "title": "RealmCraft Speicherstand",
  "description": "Maschinenlesbarer Spielstand für das spielleitergeführte Aufbau- und Erzählspiel. Wird als kanonischer JSON-Block in den hybriden Markdown-Speicherstand eingebettet oder als reine .json-Datei geladen.",
  "type": "object",
  "required": ["schemaVersion", "meta", "volk", "grundgroessen", "lagewerte", "berater", "maechte"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "meta": {
      "type": "object",
      "required": ["kapitel", "zeit", "weltereignis"],
      "properties": {
        "spielname": { "type": "string", "description": "Name der Kampagne, z. B. 'Die Karren'. Das System heißt RealmCraft." },
        "kapitel": { "type": "integer", "minimum": 1 },
        "zeit": {
          "type": "object",
          "required": ["jahreszeit", "jahr"],
          "properties": {
            "jahreszeit": { "type": "string", "enum": ["Frühling", "Sommer", "Herbst", "Winter"] },
            "jahr": { "type": "integer", "minimum": 0 }
          }
        },
        "rundeOffen": { "type": "boolean" },
        "weltereignis": { "type": "string", "enum": ["offen", "gewürfelt"] },
        "visualStyle": { "type": "string", "description": "Globaler Stil-Anker für Portraits." },
        "mapStyle": { "type": "string", "description": "Stil-Anker für die Karte." }
      }
    },
    "volk": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "wesensart": { "type": "string" },
        "ausrichtung": { "type": "string" },
        "erscheinung": { "type": "string" },
        "region": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "gelaendewerte": { "type": "array", "items": { "$ref": "#/definitions/kennwert" } }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "ansehen": {
          "type": "object",
          "properties": {
            "stufe": { "type": "integer" },
            "label": { "type": "string" }
          }
        }
      }
    },
    "grundgroessen": {
      "type": "object",
      "required": ["nahrung", "material", "wissen"],
      "properties": {
        "nahrung": { "type": "integer" },
        "material": { "type": "integer" },
        "wissen": { "type": "integer" },
        "bevoelkerung": {
          "type": "object",
          "properties": {
            "zahl": { "type": ["integer", "null"] },
            "label": { "type": "string" }
          }
        }
      }
    },
    "lagewerte": {
      "type": "object",
      "required": ["verteidigung", "mobilitaet", "wohlstand"],
      "properties": {
        "verteidigung": { "type": "integer" },
        "mobilitaet": { "type": "integer" },
        "wohlstand": { "type": "integer" },
        "ausbeuten": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "number" },
              "quelle": { "type": "string" }
            }
          }
        }
      }
    },
    "modifikatoren": {
      "type": "object",
      "properties": {
        "gelaende": { "type": "array", "items": { "$ref": "#/definitions/kennwert" } },
        "lage": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "number" },
              "grund": { "type": "string" }
            }
          }
        }
      }
    },
    "faehigkeiten": { "type": "array", "items": { "type": "string" } },
    "gruppen": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "name": { "type": "string" },
          "sprecherId": { "type": "string" },
          "kompetenz": { "type": "string" },
          "bild": { "$ref": "#/definitions/portrait" }
        }
      }
    },
    "berater": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "loyalitaet"],
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "name": { "type": "string" },
          "rolle": { "type": "string" },
          "ziel": { "type": "string" },
          "loyalitaet": { "type": "integer", "minimum": -5, "maximum": 5 },
          "generation": { "type": "string" },
          "lebensstand": { "$ref": "#/definitions/lebensstand" },
          "erscheinung": { "type": "string" },
          "portrait": { "$ref": "#/definitions/portrait" }
        }
      }
    },
    "personen": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "name": { "type": "string" },
          "rolle": { "type": "string" },
          "lebensstand": { "$ref": "#/definitions/lebensstand" },
          "erscheinung": { "type": "string" },
          "portrait": { "$ref": "#/definitions/portrait" }
        }
      }
    },
    "maechte": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "name": { "type": "string" },
          "typ": { "type": "string" },
          "erscheinung": { "type": "string" },
          "profil": { "type": "array", "items": { "$ref": "#/definitions/kennwert" } },
          "beziehung": {
            "type": "object",
            "properties": {
              "wert": { "type": ["number", "null"] },
              "label": { "type": "string" }
            }
          },
          "haltung": { "type": "string" },
          "bild": { "$ref": "#/definitions/portrait" }
        }
      }
    },
    "besitz": { "type": "array", "items": { "type": "string" } },
    "verfassung": {
      "type": "object",
      "properties": { "text": { "type": "string" } }
    },
    "beziehungenAnsehen": {
      "type": "object",
      "properties": { "text": { "type": "string" } }
    },
    "historie": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kapitel", "zusammenfassung"],
        "properties": {
          "kapitel": { "type": "integer" },
          "jahre": { "type": "string" },
          "zusammenfassung": { "type": "string" },
          "bild": {
            "type": "object",
            "description": "Optionales Ereignis-Bild der Jahreszeit. Inhalt (anlass, prompt) vom Spielleiter; bildCacheKey und Anzeige vom Frontend.",
            "properties": {
              "anlass": { "type": "string" },
              "prompt": { "type": "string" },
              "bildCacheKey": { "type": "string" }
            }
          }
        }
      }
    },
    "offeneFaeden": { "type": "array", "items": { "type": "string" } },
    "trends": {
      "type": "object",
      "description": "Optionaler Trend je Grundgröße (steigend, fallend, gleichbleibend) mit kurzem Grund.",
      "additionalProperties": {
        "type": "object",
        "required": ["richtung"],
        "properties": {
          "richtung": { "type": "string", "enum": ["steigend", "fallend", "gleichbleibend"] },
          "grund": { "type": "string" }
        }
      }
    },
    "runde": {
      "type": "object",
      "description": "Optionales Aktionsbrett der laufenden Runde: Haupt- und Nebenaktionen mit Ziel, Modifikator, Status und (nach dem Wurf) Wurf und Ergebnis.",
      "properties": {
        "haupt": { "$ref": "#/definitions/aktionsbudget" },
        "neben": { "$ref": "#/definitions/aktionsbudget" },
        "aktionen": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["art", "titel"],
            "properties": {
              "id": { "$ref": "#/definitions/id" },
              "art": { "type": "string", "enum": ["haupt", "neben"] },
              "titel": { "type": "string" },
              "kern": { "type": "string", "description": "Drei-Wort-Kern des Vorhabens." },
              "folge": { "type": "string", "description": "Klartext-Folge des Vorhabens." },
              "ziel": { "type": "integer" },
              "mod": { "type": "integer" },
              "status": { "type": "string", "enum": ["gewaehlt", "frei"] },
              "wurf": { "type": ["integer", "null"] },
              "ergebnis": { "type": ["string", "null"], "description": "Nach dem Wurf: Erfolg/Misserfolg und Folge." }
            }
          }
        }
      }
    },
    "setzungen": {
      "type": "array",
      "description": "Optionale Sonderregeln dieses Spiels, ergänzend zur Mechanik (z. B. Lebensstand, Nachfolge, Delegationsregiment).",
      "items": {
        "type": "object",
        "required": ["titel", "text"],
        "properties": {
          "titel": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "karte": {
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "bildCacheKey": { "type": "string" },
        "dataUrl": { "type": "string" },
        "aktuellerStand": { "type": "string" },
        "chronik": {
          "type": "array",
          "description": "Optionale Karten-Chronik: Folge von Karten-Ständen, jeder kann über basiertAuf aus dem vorigen entwickelt werden (Bild-zu-Bild).",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "$ref": "#/definitions/id" },
              "zeit": { "type": "string" },
              "anlass": { "type": "string" },
              "prompt": { "type": "string" },
              "basiertAuf": { "type": ["string", "null"] },
              "bildCacheKey": { "type": "string" }
            }
          }
        },
        "orte": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "$ref": "#/definitions/id" },
              "name": { "type": "string" },
              "typ": { "type": "string" },
              "richtung": { "type": "string" },
              "beziehung": { "type": "string" }
            }
          }
        }
      }
    },
    "armee": {
      "type": "object",
      "description": "Optionale Streitmacht: Verbände, stehende Modifikatoren, Verluste.",
      "properties": {
        "gesamt": { "type": "integer" },
        "moral": { "type": "string" },
        "bild": { "$ref": "#/definitions/portrait" },
        "verbaende": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "$ref": "#/definitions/id" },
              "name": { "type": "string" },
              "typ": { "type": "string" },
              "fuehrungId": { "type": "string" },
              "staerke": { "type": "integer" },
              "verfassung": { "type": "string" },
              "ausruestung": { "type": "string" },
              "hinweis": { "type": "string" },
              "avatar": { "$ref": "#/definitions/portrait" }
            }
          }
        },
        "stehendeModifikatoren": {
          "type": "array",
          "items": { "$ref": "#/definitions/kennwert" }
        },
        "verluste": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "zeit": { "type": "string" },
              "zahl": { "type": "integer" },
              "anlass": { "type": "string" }
            }
          }
        }
      }
    },
    "lebenswelt": {
      "type": "object",
      "description": "Die Lebenswelt des Volkes als Oberbegriff: wie die Bevölkerung lebt (über alle Siedlungen) und die einzelnen Siedlungen samt Hauptstadt. Wächst mit: spätere Siedlungen kommen als weitere Einträge in 'siedlungen' hinzu. Die Bevölkerungszahl bleibt in grundgroessen.bevoelkerung; hier wird sie nur gespiegelt.",
      "properties": {
        "leben": {
          "type": "object",
          "description": "Wie das Volk lebt, über alle Siedlungen hinweg: kurze Stichzeilen, keine Episodenprotokolle.",
          "properties": {
            "stimmung": { "type": "string" },
            "nahrung": { "type": "string" },
            "trinken": { "type": "string" },
            "glaube": { "type": "string", "description": "Religion, Glaube, Weltbild der Bevölkerung." },
            "alltag": { "type": "string" },
            "braeuche": { "type": "array", "items": { "type": "string" } }
          }
        },
        "siedlungen": {
          "type": "array",
          "description": "Die Siedlungen des Volkes. Genau eine sollte 'hauptstadt': true tragen. Feldnamen sind mit dem älteren 'siedlung'-Objekt kompatibel.",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "id": { "$ref": "#/definitions/id" },
              "name": { "type": "string" },
              "typ": { "type": "string", "description": "Art der Siedlung, z. B. 'Hauptstadt', 'Lager am Strand', 'Außenposten'." },
              "hauptstadt": { "type": "boolean" },
              "gegruendet": { "type": "string" },
              "lage": { "type": "string", "description": "Geografische Lage in einem Satz." },
              "beschreibung": { "type": "string", "description": "Stimmungsabsatz: wie die Siedlung aussieht und wirkt." },
              "stimmung": { "type": "string" },
              "versorgung": { "type": "string", "description": "Was man hier isst und trinkt." },
              "bauten": { "type": "array", "items": { "type": "string" }, "description": "Gebäude und Anlagen als knappe Liste." },
              "eigenschaften": { "type": "array", "items": { "$ref": "#/definitions/kennwert" } },
              "prompt": { "type": "string", "description": "Optionaler Bild-Prompt; sonst wird er aus den Feldern gebaut." },
              "bild": { "$ref": "#/definitions/portrait" }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "lebensstand": { "type": "string", "enum": ["ruestig", "lebensabend", "hinfaellig"] },
    "aktionsbudget": {
      "type": "object",
      "properties": {
        "used": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "kennwert": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "number" }
      }
    },
    "portrait": {
      "type": "object",
      "properties": {
        "cacheKey": { "type": "string" },
        "prompt": { "type": "string" },
        "dataUrl": { "type": "string", "description": "Optional eingebettetes base64-Bild (data:-URL) für portable Export-Bundles." }
      }
    }
  }
}
